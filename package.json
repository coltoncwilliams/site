{
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "concurrently": "^10.0.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "css:build": "tailwindcss -i ./css/index.css -o ./dist/css/output.css --config tailwind.configs.js --minify",
    "js:build": "esbuild js/main.js --bundle --outfile=js/bundle.js",
    "js:dev": "esbuild js/main.js --bundle --outfile=js/bundle.js --watch",
    "css:dev": "tailwindcss -i ./css/index.css -o ./css/output.css --watch --config tailwind.configs.js",
    "copy:html": "cp *.html dist/",
    "copy:js": "mkdir -p dist/js && cp -r js/bundle.js dist/js/bundle.js",
    "copy:assets": "mkdir -p dist/assets && cp -r assets/* dist/assets/",
    "start": "npm run js:build && concurrently \"live-server\" \"npm:css:dev\" \"npm:js:dev\"",
    "build": "npm run clean && mkdir -p dist && npm run css:build && npm run js:build && npm run copy:html && npm run copy:js && npm run copy:assets"
  }
}
